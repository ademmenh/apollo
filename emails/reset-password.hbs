<!DOCTYPE html>
<html>
<head>
    <style>
        .container { font-family: sans-serif; padding: 20px; }
        .code { font-size: 24px; font-weight: bold; color: #dc3545; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Reset your password</h2>
        <p>Hello {{name}},</p>
        <p>You requested a password reset. Your secret code is:</p>
        <div class="code">{{code}}</div>
        <p>This code will expire in 15 minutes.</p>
        <p>If you didn't request this, please ignore this email.</p>
    </div>
</body>
</html>
