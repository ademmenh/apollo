<!DOCTYPE html>
<html>
<head>
    <style>
        .container { font-family: sans-serif; padding: 20px; }
        .code { font-size: 24px; font-weight: bold; color: #007bff; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Verify your email</h2>
        <p>Hello {{name}},</p>
        <p>Your verification code for Waslini is:</p>
        <div class="code">{{code}}</div>
        <p>This code will expire in 15 minutes.</p>
    </div>
</body>
</html>
