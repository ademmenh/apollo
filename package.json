{
    "name": "nest-starter",
    "version": "0.0.1",
    "description": "",
    "author": "ademmenh <ademmenh777@gmail.com>",
    "private": true,
    "license": "UNLICENSED",
    "main": "dist/main.js",
    "scripts": {
        "type-check": "bun tsc --noEmit",
        "attach": "docker compose logs -f nest",
        "build": "nest build",
        "build:dev": "docker compose -f docker-compose.dev.yml build",
        "build:prod": "docker compose build",
        "debug": "nest start --debug --watch",
        "remove:dev:volumes": "docker compose -f docker-compose.dev.yml down -v",
        "remove:prod:volumes": "docker compose down -v",
        "start:dev": "docker compose -f docker-compose.dev.yml --env-file .env.dev up -d",
        "stop:dev": "docker compose -f docker-compose.dev.yml down",
        "test": "bun type-check && bun test:unit && bun test:integration && bun test:e2e",
        "test:watch": "bun type-check && bun test --watch",
        "test:cov": "bun type-check && bun test --coverage",
        "test:debug": "bun --inspect-brk test:unit --runInBand",
        "test:integration": "bun test $(find ./src -name '*.integration-spec.ts')",
        "test:e2e": "bun test $(find ./src -name '*.e2e-spec.ts')",
        "test:unit": "bun test $(find src -name '*.spec.ts' -not -name '*.e2e-spec.ts' -not -name '*.integration-spec.ts')",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "db:push": "bun run drizzle-kit push",
        "db:studio": "bun run drizzle-kit studio",
        "db:generate": "bun run drizzle-kit generate",
        "db:migrate": "bun run drizzle-kit migrate",
        "db:drop": "bun run drizzle-kit drop",
        "seed": "bun src/seed.ts",
        "ws:dev": "bun --watch src/ws/ws.dev.ts",
        "ws:attach": "docker compose logs -f ws"
    },
    "dependencies": {
        "@apollo/server": "^5.5.0",
        "@as-integrations/express5": "^1.1.2",
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/apollo": "^13.2.4",
        "@nestjs/common": "^11.1.9",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.9",
        "@nestjs/graphql": "^13.2.4",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/platform-socket.io": "^11.1.17",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/websockets": "^11.1.17",
        "@types/bcryptjs": "^3.0.0",
        "@valkey/valkey-glide": "^2.2.6",
        "amqplib": "^1.0.1",
        "bcryptjs": "^3.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "cookie-parser": "^1.4.7",
        "dataloader": "^2.2.3",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.39.0",
        "graphql": "^16.13.2",
        "h3-js": "^4.4.0",
        "handlebars": "^4.7.8",
        "joi": "^18.0.1",
        "nodemailer": "^8.0.1",
        "passport": "0.6.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/amqplib": "^0.10.8",
        "@types/cookie-parser": "^1.4.9",
        "@types/express": "^5.0.0",
        "@types/node": "^24.10.1",
        "@types/pg": "^8.11.0",
        "@types/supertest": "^6.0.2",
        "bun-types": "^1.3.8",
        "drizzle-kit": "^0.30.0",
        "eslint": "^10.0.3",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.4.0",
        "prettier": "^3.4.2",
        "supertest": "^7.0.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.57.1"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}